# Server
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=60s

# Database - Default (main metadata)
DB_DEFAULT_DSN=user:pass@tcp(host:3306)/dbname?parseTime=true&loc=UTC

# Database - Regional Trip Pools
DB_TRIPPOOL_TH_DSN=user:pass@tcp(th-host:3306)/trippool?parseTime=true&loc=UTC
DB_TRIPPOOL_IN_DSN=user:pass@tcp(in-host:3306)/trippool?parseTime=true&loc=UTC
DB_TRIPPOOL_EU_DSN=user:pass@tcp(eu-host:3306)/trippool?parseTime=true&loc=UTC
DB_TRIPPOOL_ASIA1_DSN=user:pass@tcp(asia1-host:3306)/trippool?parseTime=true&loc=UTC
DB_TRIPPOOL_ASIA2_DSN=user:pass@tcp(asia2-host:3306)/trippool?parseTime=true&loc=UTC

# Cache
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Event Bus
NATS_URL=nats://localhost:4222

# Recheck Service
RECHECK_BASE_URL=https://recheck.internal.12go.asia

# Feature Flags
FEATURE_ROUND_TRIPS=true
FEATURE_AUTOPACKS=true
FEATURE_MULTISELLER=true

# Observability
LOG_LEVEL=info
METRICS_PORT=9090
OTEL_EXPORTER_ENDPOINT=localhost:4317
